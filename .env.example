## Isolates Docker Compose project (containers, networks, volumes).
COMPOSE_PROJECT_NAME=canary
# Start the nginx `frontend` service (not `frontend_dev`); required for a built UI. Use `dev` only with docker-compose.dev.yml.
COMPOSE_PROFILES=prod
# Required secrets
# App auth secret (JWT signing only — rotating this logs users out but does not affect stored IMAP/portal secrets
# once DATA_ENCRYPTION_KEY is set and scripts/reencrypt_data_secrets.py has been run).
JWT_SECRET=############################################
# Fernet key for encrypting stored secrets (IMAP/SMTP, Graph client secret, portal codes, CalDAV passwords).
# Generate once: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# After first deploy with this key on an existing database, run: python scripts/reencrypt_data_secrets.py
DATA_ENCRYPTION_KEY=############################################
# Staff auth rate limits (optional overrides; defaults match client portal lockout)
# STAFF_LOGIN_MAX_FAILED_ATTEMPTS=5
# STAFF_LOGIN_LOCKOUT_MINUTES=15
# STAFF_LOGIN_IP_MAX_FAILED_ATTEMPTS=25
# PORTAL_AUTH_IP_MAX_FAILED_ATTEMPTS=25
# PORTAL_AUTH_LOCKOUT_MINUTES=15
# PORTAL_OTP_REQUEST_EMAIL_MAX_ATTEMPTS=5
# PORTAL_OTP_REQUEST_IP_MAX_ATTEMPTS=15
# PORTAL_OTP_REQUEST_LOCKOUT_MINUTES=15
# PORTAL_OTP_VERIFY_EMAIL_MAX_FAILED_ATTEMPTS=5
# PORTAL_OTP_VERIFY_IP_MAX_FAILED_ATTEMPTS=25
# PORTAL_OTP_VERIFY_LOCKOUT_MINUTES=15
# FORGOT_PASSWORD_MAX_ATTEMPTS=5
# FORGOT_PASSWORD_LOCKOUT_MINUTES=15
# FORGOT_PASSWORD_IP_MAX_ATTEMPTS=15
# Reject unsigned ONLYOFFICE save callbacks (DS 9.x sends JWT). Set 0 only for legacy Document Server.
ONLYOFFICE_CALLBACK_REQUIRE_JWT=1
# ONLYOFFICE signing secret (used by both backend and onlyoffice services).
ONLYOFFICE_JWT_SECRET=#########################################
ONLYOFFICE_SECURE_LINK_SECRET=######################################
# Master recovery operator (break-glass; configured only in .env — not a DB user).
# Use long random hex strings; login id need not be a real e-mail address.
MASTER_ADMIN_LOGIN=################################
MASTER_ADMIN_PASSWORD=################################
# Master recovery sign-in requires a TOTP code by default. Set false in .env to bypass (break-glass).
MASTER_ADMIN_REQUIRE_2FA=true
# Base32 TOTP secret — generate: python -c "import pyotp; print(pyotp.random_base32())"
MASTER_ADMIN_TOTP_SECRET=################################
TOTP_ISSUER=Canary
# WebAuthn / passkeys (browser Origin header required). Set RP ID to the hostname users open (no port), e.g. app.example.com
# WEBAUTHN_RP_ID=
# WEBAUTHN_RP_NAME=Canary
# Public app URLs — CANARY_PUBLIC_URL is the main origin for links (single value; no comma list).
# CANARY_CORS_ORIGINS: comma-separated browser Origins allowed to call the API (include every subdomain you use, e.g. https://app.example.com,https://app2.example.com).
CANARY_PUBLIC_URL=#######################
# Outlook add-in: every https:// URL in frontend/public/outlook-addin/manifest.xml must match
# CANARY_PUBLIC_URL (committed file uses placeholder https://YOUR_CANARY_PUBLIC_URL). The frontend
# Docker build rewrites dist/outlook-addin/manifest.xml from this value before nginx serves it.
# After deploy, confirm https://YOUR_HOST/outlook-addin/manifest.xml shows your origin, then
# re-upload the manifest in M365 admin or re-sideload in Outlook desktop/OWA.
CANARY_CORS_ORIGINS=#######################
ONLYOFFICE_DS_PUBLIC_URL=#################### 
CANARY_CALDAV_PUBLIC_URL=####################
# Trust X-Forwarded-* from Docker/nginx and loopback only (not * in production).
CANARY_PROXY_TRUSTED_HOSTS=127.0.0.1,172.16.0.0/12,::1
# ONLYOFFICE backend-side routing tweaks (leave blank unless needed)
ONLYOFFICE_APP_URL_INTERNAL=
ONLYOFFICE_PREFER_IPV4_FOR_DS=
ONLYOFFICE_DOCUMENT_URL=
RADICALE_INTERNAL_URL=http://radicale:5232         #DO NOT TOUCH
# Published host ports for this stack (must be unique on the machine; Postgres is not 5432 on purpose).
BACKEND_PORT_PUBLISH=127.0.0.1:8004:8000
# Prod nginx: loopback for cloudflared/host proxy + Tailscale IP for tailnet admin (see `tailscale ip -4`).
FRONTEND_PORT_PUBLISH=127.0.0.1:8080:80
FRONTEND_TAILSCALE_PORT_PUBLISH=100.x.x.x:8080:80
# Local dev only (cloudflared in Docker): set to 172.17.0.1:8080:80 — see `ip -4 addr show docker0`.
# Prefer docker-compose.dev-tunnel.yml instead (handles cloudflared + origin automatically).
FRONTEND_DOCKER_HOST_PORT_PUBLISH=127.0.0.3:8080:80
# Cloudflare Tunnel token for dev.canarylegalsoftware.co.uk (docker-compose.dev-tunnel.yml only).
# CLOUDFLARE_TUNNEL_TOKEN_DEV=
# Dev Vite: same pattern on port 5173 when using --profile dev.
FRONTEND_DEV_PORT_PUBLISH=127.0.0.1:5173:5173
FRONTEND_DEV_TAILSCALE_PORT_PUBLISH=100.x.x.x:5173:5173
RADICALE_PORT_PUBLISH=127.0.0.1:5232:5232
ONLYOFFICE_PORT_PUBLISH=127.0.0.1:18084:80
POSTGRES_PORT_PUBLISH=127.0.0.1:5436:5432
# Frontend build/runtime options
VITE_API_BASE=
VITE_ONLYOFFICE_URL=/office-ds
VITE_ONLYOFFICE_DIRECT_PORT=
VITE_ONLYOFFICE_DIRECT_URL=
# Opt-in (this deployment only): open case PDFs in ONLYOFFICE instead of the browser viewer.
# Set both to 1, then rebuild backend + frontend. Default off for other installs.
# CANARY_OPEN_PDF_IN_ONLYOFFICE=1
# VITE_CANARY_OPEN_PDF_IN_ONLYOFFICE=1
# Document Server major: auto (probe at runtime), 7, or 9. Native PDF editor needs DS 8+ (in-place save: 9.0.3+).
# ONLYOFFICE_DS_MAJOR=auto
# Microsoft Graph (optional — New > E-mail → Outlook draft in user mailbox; application permissions + admin consent)
# Also used by:
#   POST /api/outlook-plugin/ensure-master-category — seed Outlook master category list
#   POST /api/outlook-plugin/graph-tag-category — PATCH message categories when the add-in’s Office.js path fails
# Grant in Entra ID (application) at minimum what you use for drafts, plus:
#   **MailboxSettings.ReadWrite** — master category list
#   **Mail.ReadWrite** — read/PATCH mesages for graph-tag-category
CANARY_MS_GRAPH_TENANT_ID=##############
CANARY_MS_GRAPH_CLIENT_ID=##############
CANARY_MS_GRAPH_CLIENT_SECRET=#############
# OWA base for compose deeplinks (use your tenant host, e.g. outlook.cloud.microsoft/mail)
CANARY_OUTLOOK_WEB_MAIL_BASE=https://outlook.cloud.microsoft/mail
# Category applied to new drafts (Exchange display name; create “Canary” in Outlook if missing)
CANARY_OUTLOOK_CATEGORY_NAME=Canary
# --- PostgreSQL ---
# Used by the `db` service and by the backend entrypoint to build DATABASE_URL (password is URL-encoded).
# The data volume stores the password from the *first* `docker compose up`; changing POSTGRES_PASSWORD
# later without recreating the volume causes auth errors — see comments in previous sections if needed.
POSTGRES_USER=canary
POSTGRES_PASSWORD=###############################
POSTGRES_DB=canary
# Optional: full URL; if set, POSTGRES_* above are not used to build DATABASE_URL for the backend.
# DATABASE_URL=postgresql+psycopg://canary:encodedpass@db:5432/canary

# --- Admin “Update now” / Deploy ---
#
# This repo’s docker-compose.yml mounts the host Docker socket and this checkout at /canary-compose into backend
# by default. Change those volumes if your host layout differs; CANARY_COMPOSE_PROJECT_DIR must match the in-container path.
#
# Self-hosted GUI “Update now” (runs Docker Compose on the host from inside backend). No GitHub account required.
CANARY_COMPOSE_UPDATE_ENABLED=1
CANARY_COMPOSE_PROJECT_DIR=/canary-compose
CANARY_COMPOSE_PROFILES=prod
CANARY_COMPOSE_FILES=docker-compose.yml
# Pull latest git before compose-driven pull/build when the mount is rw and contains .git (typical self-host).
CANARY_COMPOSE_GIT_PULL=1
# Opt-in: allow Admin “Reset to GitHub & update” (git fetch + reset --hard to CANARY_GITHUB_DEPLOY_REF, then compose).
# Discards local commits and uncommitted changes to tracked files in the checkout — use with care.
CANARY_COMPOSE_GIT_RESET_ENABLED=1
#
# docker compose up -d uses a one-shot runner by default inside Docker (CANARY_COMPOSE_ISOLATED_UP) so the backend
# container is not recreated while it is still the compose client. Override only if you need to:
# CANARY_COMPOSE_ISOLATED_UP=1
# CANARY_COMPOSE_RUNNER_IMAGE=docker:27-cli
# If bind mounts from the runner fail, set the repo’s absolute path on the Docker host:
# CANARY_COMPOSE_HOST_PROJECT_DIR=/path/on/host/to/canarycms
# Compose job state and compose-up markers (default: <CANARY_COMPOSE_PROJECT_DIR>/.canary/runtime).
# Not stored under FILES_ROOT (/data/files).
# CANARY_COMPOSE_RUNTIME_DIR=/canary-compose/.canary/runtime
#
# Security: docker.sock gives the backend root-level control over the host Docker daemon — keep Admin access tight.
#
# GitHub read-only API: Admin → Deploy compares this install to the branch tip (post-login prompt optional).
# Uses the public GitHub API only (no token). Private repos are not supported for update checks.
# Use your fork’s owner/repo/ref if your running commit is not on canarylegal/canarycms.
CANARY_GITHUB_DEPLOY_OWNER=canarylegal
CANARY_GITHUB_DEPLOY_REPO=canarycms
CANARY_GITHUB_DEPLOY_REF=main
#
# To deploy from GitHub Actions, trigger workflows manually or via CI in the repository (not from this app).
#
# GIT_COMMIT is a **build arg** (docker-compose.yml → backend image). Set at build time so CANARY_BUILD_COMMIT matches
# your tree, e.g. GIT_COMMIT=$(git rev-parse HEAD) docker compose build backend. A stale value in .env alone does not
# change a running image until you rebuild.
# GIT_COMMIT=
#
# Prefer git rev-parse HEAD on the mounted compose tree for /health vs the image-baked SHA. auto (default
# in code when unset or empty): enable when CANARY_COMPOSE_PROJECT_DIR exists. Set 0 to use only the baked label.
# Admin update checks prefer the baked image commit when known (see build_metadata.py).
CANARY_RUNTIME_COMMIT_FROM_COMPOSE_REPO=auto
#
# Optional: force the commit string for /health + GitHub checks (e.g. dev bind-mount). Example: same as git rev-parse HEAD
# CANARY_BUILD_COMMIT_OVERRIDE=
# Disable post-login update prompt for admins:
# CANARY_UPDATE_PROMPT_ON_LOGIN=0
