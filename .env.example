## Isolates Docker Compose project (containers, networks, volumes).
COMPOSE_PROJECT_NAME=canary
# Start the nginx `frontend` service (not `frontend_dev`); required for a built UI. Use `dev` only with docker-compose.dev.yml.
COMPOSE_PROFILES=prod
# Required secrets
# App auth secret.
JWT_SECRET=############################################
# ONLYOFFICE signing secret (used by both backend and onlyoffice services).
ONLYOFFICE_JWT_SECRET=#########################################
ONLYOFFICE_SECURE_LINK_SECRET=######################################
BOOTSTRAP_ADMIN_TOKEN=#############################
TOTP_ISSUER=Canary
# WebAuthn / passkeys (browser Origin header required). Set RP ID to the hostname users open (no port), e.g. app.example.com
# WEBAUTHN_RP_ID=
# WEBAUTHN_RP_NAME=Canary
# Public app URLs — CANARY_PUBLIC_URL must be the exact origin users open (e.g. https://demo.example.com).
# CANARY_CORS_ORIGINS: same origin(s), comma-separated if the app is reachable under more than one hostname.
CANARY_PUBLIC_URL=#######################
CANARY_CORS_ORIGINS=#######################
ONLYOFFICE_DS_PUBLIC_URL=#################### 
CANARY_CALDAV_PUBLIC_URL=####################
# Trust X-Forwarded-* from your outer reverse proxy (Cloudflare, host nginx, etc.). If login/API URLs look
# like http:// instead of https://, set * or add your proxy’s source IPs/ranges (see docker-compose backend env).
CANARY_PROXY_TRUSTED_HOSTS=*
# ONLYOFFICE backend-side routing tweaks (leave blank unless needed)
ONLYOFFICE_APP_URL_INTERNAL=
ONLYOFFICE_PREFER_IPV4_FOR_DS=
ONLYOFFICE_DOCUMENT_URL=
RADICALE_INTERNAL_URL=http://radicale:5232         #DO NOT TOUCH
# Published host ports for this stack (must be unique on the machine; Postgres is not 5432 on purpose).
BACKEND_PORT_PUBLISH=0.0.0.0:8004:8000
# host:container — nginx listens on 80 in the image; use e.g. 8080:80 to open http://localhost:8080/
FRONTEND_PORT_PUBLISH=0.0.0.0:8080:80
FRONTEND_DEV_PORT_PUBLISH=0.0.0.0:5173:5173
RADICALE_PORT_PUBLISH=0.0.0.0:5232:5232
ONLYOFFICE_PORT_PUBLISH=0.0.0.0:18084:80
POSTGRES_PORT_PUBLISH=0.0.0.0:5436:5432
# Frontend build/runtime options
VITE_API_BASE=
VITE_ONLYOFFICE_URL=/office-ds
VITE_ONLYOFFICE_DIRECT_PORT=
VITE_ONLYOFFICE_DIRECT_URL=
# Microsoft Graph (optional — New > E-mail → Outlook draft in user mailbox; application permissions + admin consent)
# Also used by:
#   POST /api/outlook-plugin/ensure-master-category — seed Outlook master category list
#   POST /api/outlook-plugin/graph-tag-category — PATCH message categories when the add-in’s Office.js path fails
# Grant in Entra ID (application) at minimum what you use for drafts, plus:
#   **MailboxSettings.ReadWrite** — master category list
#   **Mail.ReadWrite** — read/PATCH mesages for graph-tag-category
CANARY_MS_GRAPH_TENANT_ID=##############
CANARY_MS_GRAPH_CLIENT_ID=##############
CANARY_MS_GRAPH_CLIENT_SECRET=#############
# OWA base for compose deeplinks (default outlook.office.com/mail)
CANARY_OUTLOOK_WEB_MAIL_BASE=https://outlook.office.com/mail
# Category applied to new drafts (Exchange display name; create “Canary” in Outlook if missing)
CANARY_OUTLOOK_CATEGORY_NAME=Canary
# --- PostgreSQL ---
# Used by the `db` service and by the backend entrypoint to build DATABASE_URL (password is URL-encoded).
# The data volume stores the password from the *first* `docker compose up`; changing POSTGRES_PASSWORD
# later without recreating the volume causes auth errors — see comments in previous sections if needed.
POSTGRES_USER=canary
POSTGRES_PASSWORD=###############################
POSTGRES_DB=canary
# Optional: full URL; if set, POSTGRES_* above are not used to build DATABASE_URL for the backend.
# DATABASE_URL=postgresql+psycopg://canary:encodedpass@db:5432/canary

# --- Admin “Update now” / Deploy ---
#
# Self-hosted default: run Docker Compose from the backend container (no GitHub account needed).
# Requires mounting the host Docker socket and the compose project directory into `backend`, then:
#   CANARY_COMPOSE_UPDATE_ENABLED=1
#   CANARY_COMPOSE_PROJECT_DIR=/canary-compose          # path inside container → must match your volume mount
#   CANARY_COMPOSE_PROFILES=prod                        # compose profiles (space- or comma-separated)
#   CANARY_COMPOSE_FILES=docker-compose.yml           # or docker-compose.yml,docker-compose.override.yml
# Optional: pull latest git before build (repo must be mounted rw and contain .git):
#   CANARY_COMPOSE_GIT_PULL=1
# Security: docker.sock gives the backend root-level control over the host’s Docker daemon — keep Admin access tight.
# Example backend volumes (uncomment in docker-compose.yml):
#   - /var/run/docker.sock:/var/run/docker.sock
#   - /absolute/path/to/canarycms:/canary-compose:rw
#
# CANARY_COMPOSE_UPDATE_ENABLED=
# CANARY_COMPOSE_PROJECT_DIR=
# CANARY_COMPOSE_PROFILES=prod
# CANARY_COMPOSE_FILES=docker-compose.yml
# CANARY_COMPOSE_GIT_PULL=
#
# GitHub (read-only, for Admin → Deploy “check for updates” vs branch tip + post-login prompt). Public repos
# do not need CANARY_GITHUB_DEPLOY_TOKEN. Forks: change OWNER/REPO; air-gapped: comment all three lines out.
CANARY_GITHUB_DEPLOY_OWNER=canarylegal
CANARY_GITHUB_DEPLOY_REPO=canarycms
CANARY_GITHUB_DEPLOY_REF=main
#CANARY_GITHUB_DEPLOY_TOKEN=   # only if the repo is private or you hit anonymous GitHub API rate limits
#
# Triggering GitHub Actions from the app (workflow_dispatch) is optional and needs a PAT plus a self-hosted
# runner — see .github/workflows/deploy-canary.yml and backend ``github_deploy``; not listed here by default.
#Bake git SHA into backend image (enables “update available” vs GitHub). Example: GIT_COMMIT=$(git rev-parse HEAD) docker compose build backend
#GIT_COMMIT=
# Optional: force the commit string used for /health + GitHub update checks when it differs from the image bake
# (e.g. backend bind-mounted in dev, or correcting a mis-labelled image). Example: CANARY_BUILD_COMMIT_OVERRIDE=$(git rev-parse HEAD)
# CANARY_BUILD_COMMIT_OVERRIDE=
# Disable post-login update prompt for admins: CANARY_UPDATE_PROMPT_ON_LOGIN=0
# CANARY_UPDATE_PROMPT_ON_LOGIN=1
