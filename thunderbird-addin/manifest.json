{
  "manifest_version": 2,
  "name": "Canary — file to matter",
  "version": "1.4.1",
  "description": "File mail to a matter; compose from a matter with merge and attachments; apply the Canary message tag.",
  "author": "Canary",
  "applications": {
    "gecko": {
      "id": "canary-file@canarylegal.co.uk",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": [
      "tag-apply.js",
      "canary-windows.js",
      "canary-shared.js",
      "compose-store.js",
      "compose-apply.js",
      "message-view-cache.js",
      "compose-prefill.js",
      "compose-send.js",
      "compose-auto-open.js",
      "compose-compose-action.js",
      "filing-menu.js",
      "background.js"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon64.png",
    "128": "icons/icon128.png"
  },
  "browser_action": {
    "default_title": "Canary — file mail",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "compose_action": {
    "default_title": "Canary — matter & attach",
    "default_popup": "compose-panel/panel.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "message_display_action": {
    "default_title": "Canary — file",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "permissions": [
    "storage",
    "menus",
    "accountsRead",
    "messagesRead",
    "messagesUpdate",
    "messagesTags",
    "messagesTagsList",
    "compose",
    "compose.send",
    "<all_urls>"
  ]
}
